# 环境变量示例；只填写本机值，不要提交真实密钥。
# Environment variable examples; use local values and never commit a real key.
# 修改时间 / Last updated: 2026-07-02 01:32 (Asia/Shanghai)

# HTTP 服务端口 / HTTP server port
SERVER_PORT=8080

# SSE 请求超时时间 / SSE request timeout
CHAT_STREAM_TIMEOUT=5m

# 模型提供者标识 / Model provider label
AI_PROVIDER=deepseek

# DeepSeek API 密钥，必填且不得提交 / Required DeepSeek API key; never commit it
DEEPSEEK_API_KEY=

# DeepSeek API 根地址 / DeepSeek API root URL
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称 / DeepSeek model name
DEEPSEEK_MODEL=deepseek-v4-flash

# 可选企业聊天话术 / Optional company chat instructions
AI_SYSTEM_PROMPT=You are a helpful assistant. Answer clearly and concisely.

# 每个会话最多保留的消息数（2-100）/ Maximum retained messages per conversation (2-100)
AI_MEMORY_MAX_MESSAGES=20
